# Outlook SMTP credentials for the MCP email server.
# Generate an App Password at:
#   account.live.com -> Security -> Advanced security options -> App passwords
# Regular Outlook password will NOT work if MFA is enabled.

SMTP_USER=thejazrameshan@outlook.com
SMTP_APP_PASSWORD=replace-with-16-char-app-password

# Optional overrides (defaults shown).
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587

# Display name used in the From: header.
SMTP_FROM_NAME=Thejaz Rameshan

# Qdrant connection.
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Ollama model.
OLLAMA_MODEL=phi4-mini
